---
const headline = "YOUR CUSTOM BUILDER IN EAST TEXAS";
const words = headline.split(' ');
---

<section
  id="hero"
  class="relative w-full h-screen min-h-[600px] overflow-hidden flex items-end pb-20 md:pb-32"
  aria-label="Hero"
>
  <!-- Cinematic background image -->
  <img
    id="hero-bg"
    src="/images/img_1.jpg"
    alt="Luxury custom home built by L&L Builders in East Texas"
    width="1920"
    height="1080"
    fetchpriority="high"
    class="absolute inset-0 w-full h-full object-cover object-center scale-110"
  />

  <!-- Gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-t from-brand-crimson via-brand-crimson/50 to-transparent" />
  <div class="absolute inset-0 bg-gradient-to-r from-brand-crimson/60 to-transparent" />

  <!-- Content -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:px-12">

    <!-- Eyebrow -->
    <p
      id="hero-eyebrow"
      class="opacity-0 font-nav font-light text-brand-gold text-sm md:text-base tracking-[0.3em] uppercase mb-4"
    >
      East Texas &mdash; Est. 1994
    </p>

    <!-- Headline word-by-word reveal -->
    <h1 class="font-heading font-black text-5xl md:text-7xl lg:text-8xl text-white leading-tight mb-6 max-w-4xl">
      {words.map((word) => (
        <span class="hero-word inline-block overflow-hidden mr-3 md:mr-4">
          <span class="hero-word-inner inline-block translate-y-full opacity-0">{word}</span>
        </span>
      ))}
    </h1>

    <!-- Subline -->
    <p
      id="hero-subline"
      class="opacity-0 font-accent italic text-white/80 text-xl md:text-2xl mb-10 max-w-xl"
    >
      Transforming visions into timeless realities — one home at a time.
    </p>

    <!-- CTAs -->
    <div id="hero-ctas" class="opacity-0 flex flex-col sm:flex-row gap-4">
      <a
        href="#projects"
        class="inline-block px-8 py-4 bg-brand-gold text-white font-body font-bold text-sm tracking-widest uppercase hover:bg-brand-gold-light transition-colors duration-300"
      >
        View Our Work
      </a>
      <a
        href="#contact"
        class="inline-block px-8 py-4 border border-white/50 text-white font-body font-light text-sm tracking-widest uppercase hover:border-brand-gold hover:text-brand-gold transition-colors duration-300"
      >
        Get a Quote
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    id="hero-scroll"
    class="opacity-0 absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/40 text-xs tracking-widest uppercase"
  >
    <span>Scroll</span>
    <div class="w-px h-10 bg-white/30" />
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

  // Hero entrance sequence
  tl
    .to('#hero-eyebrow', { opacity: 1, y: 0, duration: 0.7, delay: 0.5 })
    .to('.hero-word-inner', {
      translateY: '0%',
      opacity: 1,
      duration: 0.7,
      stagger: 0.07,
      ease: 'power4.out',
    }, '-=0.2')
    .to('#hero-subline', { opacity: 1, y: 0, duration: 0.8 }, '-=0.3')
    .to('#hero-ctas', { opacity: 1, y: 0, duration: 0.7 }, '-=0.4')
    .to('#hero-scroll', { opacity: 1, duration: 0.5 }, '-=0.2');

  gsap.set('#hero-eyebrow', { y: 20 });
  gsap.set('#hero-subline', { y: 20 });
  gsap.set('#hero-ctas', { y: 20 });

  // Scroll indicator bounce
  gsap.to('#hero-scroll', {
    y: 8,
    repeat: -1,
    yoyo: true,
    duration: 1,
    ease: 'power1.inOut',
    delay: 2.5,
  });

  // Parallax on hero bg
  gsap.to('#hero-bg', {
    yPercent: 25,
    ease: 'none',
    scrollTrigger: {
      trigger: '#hero',
      start: 'top top',
      end: 'bottom top',
      scrub: 1.5,
    },
  });
</script>

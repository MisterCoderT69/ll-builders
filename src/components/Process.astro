---
const steps = [
  {
    number: '01',
    title: 'Consultation',
    body: 'We start with you. A no-pressure conversation about your vision, your site, your timeline, and your budget. We listen more than we talk.',
  },
  {
    number: '02',
    title: 'Design & Planning',
    body: 'Our team works with your architect — or ours — to translate your vision into detailed plans. Open communication at every step means no surprises.',
  },
  {
    number: '03',
    title: 'Construction',
    body: 'With permits pulled and materials sourced, our vetted crews get to work. You receive regular progress updates and direct access to your project lead.',
  },
  {
    number: '04',
    title: 'Walk-Through & Delivery',
    body: "We don't hand over keys until you're completely satisfied. A thorough final walk-through ensures every detail meets our standards — and yours.",
  },
];
---

<section
  id="process"
  class="py-24 md:py-36 bg-brand-crimson overflow-hidden"
  aria-labelledby="process-heading"
>
  <div class="max-w-7xl mx-auto px-6 md:px-12">

    <!-- Heading -->
    <div class="mb-16 md:mb-24 text-center">
      <p class="process-label opacity-0 font-nav font-light text-brand-gold text-sm tracking-[0.3em] uppercase mb-4">
        How We Work
      </p>
      <h2
        id="process-heading"
        class="font-heading font-black text-5xl md:text-6xl text-white"
        style="clip-path: inset(0 100% 0 0);"
      >
        Our Process
      </h2>
    </div>

    <!-- Steps -->
    <div class="relative grid md:grid-cols-4 gap-10 md:gap-6">

      <!-- Connecting line (desktop) -->
      <div class="hidden md:block absolute top-8 left-[12.5%] right-[12.5%] h-px bg-white/10">
        <div id="process-line" class="process-line h-full" />
      </div>

      {steps.map((step) => (
        <div class="process-step opacity-0 relative text-center md:text-left">
          <!-- Number circle -->
          <div class="step-number relative mx-auto md:mx-0 w-16 h-16 rounded-full border-2 border-brand-gold/40 flex items-center justify-center mb-6 group-hover:border-brand-gold transition-colors duration-300 bg-brand-crimson">
            <span class="font-heading font-black text-xl text-brand-gold">{step.number}</span>
          </div>

          <h3 class="font-heading text-xl font-bold text-white mb-3">{step.title}</h3>
          <p class="font-accent text-white/60 text-base leading-relaxed">{step.body}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const trigger = { trigger: '#process', start: 'top 75%' };

  gsap.to('.process-label', { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out', scrollTrigger: trigger });
  gsap.to('#process-heading', { clipPath: 'inset(0 0% 0 0)', duration: 1.2, ease: 'power3.inOut', scrollTrigger: trigger });

  gsap.set('.process-label', { y: 20 });
  gsap.set('.process-step', { y: 40 });

  gsap.to('.process-step', {
    opacity: 1,
    y: 0,
    stagger: 0.2,
    duration: 0.8,
    ease: 'power3.out',
    scrollTrigger: trigger,
  });

  // Step number circles pop in
  gsap.from('.step-number', {
    scale: 0,
    opacity: 0,
    stagger: 0.2,
    duration: 0.5,
    ease: 'back.out(2)',
    scrollTrigger: trigger,
  });

  // Connector line draws across
  gsap.to('#process-line', {
    scaleX: 1,
    duration: 1.5,
    ease: 'power2.inOut',
    scrollTrigger: { trigger: '#process', start: 'top 70%' },
  });
</script>

---
---

<section
  id="contact"
  class="py-24 md:py-36 bg-brand-light overflow-hidden"
  aria-labelledby="contact-heading"
>
  <div class="max-w-7xl mx-auto px-6 md:px-12">

    <!-- Heading -->
    <div class="mb-16 max-w-2xl">
      <p class="contact-label opacity-0 font-nav font-light text-brand-gold text-sm tracking-[0.3em] uppercase mb-4">
        Start Building
      </p>
      <h2
        id="contact-heading"
        class="font-heading font-black text-5xl md:text-6xl lg:text-7xl text-white leading-tight mb-4"
        style="clip-path: inset(0 100% 0 0);"
      >
        Have a Project in Mind?
      </h2>
      <p class="contact-sub opacity-0 font-accent italic text-white/70 text-xl">
        Let's build something extraordinary together.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-16 items-start">

      <!-- Form -->
      <form
        id="contact-form"
        action="https://formsubmit.co/scarpenterenterprises@yahoo.com"
        method="POST"
        class="opacity-0 space-y-6"
        novalidate
      >
        <!-- Formsubmit hidden fields -->
        <input type="hidden" name="_subject" value="New inquiry from llandlbuilders.com" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="text" name="_honey" class="hidden" tabindex="-1" autocomplete="off" />

        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <label for="name" class="block font-nav font-light text-white/70 text-sm tracking-widest uppercase mb-2">
              Full Name *
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full bg-transparent border-0 border-b border-white/30 focus:border-brand-gold text-white placeholder-white/30 py-3 outline-none transition-colors duration-300 font-body text-base"
              placeholder="John Smith"
            />
          </div>
          <div>
            <label for="email" class="block font-nav font-light text-white/70 text-sm tracking-widest uppercase mb-2">
              Email *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-transparent border-0 border-b border-white/30 focus:border-brand-gold text-white placeholder-white/30 py-3 outline-none transition-colors duration-300 font-body text-base"
              placeholder="you@email.com"
            />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <label for="phone" class="block font-nav font-light text-white/70 text-sm tracking-widest uppercase mb-2">
              Phone
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full bg-transparent border-0 border-b border-white/30 focus:border-brand-gold text-white placeholder-white/30 py-3 outline-none transition-colors duration-300 font-body text-base"
              placeholder="(903) 000-0000"
            />
          </div>
          <div>
            <label for="project-type" class="block font-nav font-light text-white/70 text-sm tracking-widest uppercase mb-2">
              Project Type
            </label>
            <select
              id="project-type"
              name="project_type"
              class="w-full bg-brand-light border-0 border-b border-white/30 focus:border-brand-gold text-white py-3 outline-none transition-colors duration-300 font-body text-base appearance-none cursor-pointer"
            >
              <option value="" class="bg-brand-crimson">Select a type…</option>
              <option value="Custom Home" class="bg-brand-crimson">Custom Home</option>
              <option value="Lake Cabin" class="bg-brand-crimson">Lake Cabin</option>
              <option value="Commercial" class="bg-brand-crimson">Commercial</option>
              <option value="Renovation" class="bg-brand-crimson">Renovation</option>
              <option value="Other" class="bg-brand-crimson">Other</option>
            </select>
          </div>
        </div>

        <div>
          <label for="message" class="block font-nav font-light text-white/70 text-sm tracking-widest uppercase mb-2">
            Tell Us About Your Vision *
          </label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full bg-transparent border-0 border-b border-white/30 focus:border-brand-gold text-white placeholder-white/30 py-3 outline-none transition-colors duration-300 font-body text-base resize-none"
            placeholder="Describe your project, location, timeline, and anything else we should know…"
          ></textarea>
        </div>

        <button
          id="contact-submit"
          type="submit"
          class="inline-block px-10 py-4 bg-brand-gold text-white font-body font-bold text-sm tracking-[0.2em] uppercase hover:bg-brand-gold-light transition-all duration-300 active:scale-95"
        >
          Send Your Vision
        </button>
      </form>

      <!-- Contact alternatives -->
      <div id="contact-buttons" class="opacity-0 flex flex-col gap-6 lg:pt-20">

        <p class="font-nav font-light text-white/50 text-xs tracking-[0.25em] uppercase">
          Or reach us directly
        </p>

        <!-- WhatsApp -->
        <a
          href="https://wa.me/19034397666"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-btn flex items-center gap-5 p-6 border border-white/10 hover:border-[#25D366]/60 group transition-all duration-300"
        >
          <div class="w-12 h-12 rounded-full bg-[#25D366]/15 flex items-center justify-center group-hover:bg-[#25D366]/30 transition-colors duration-300 shrink-0">
            <svg class="w-6 h-6 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <div>
            <p class="font-heading font-bold text-white text-base group-hover:text-[#25D366] transition-colors duration-300">
              Chat on WhatsApp
            </p>
            <p class="font-body text-white/50 text-sm mt-1">903-439-7666</p>
          </div>
        </a>

        <!-- iMessage / SMS -->
        <a
          href="sms:+19034397666"
          class="contact-btn flex items-center gap-5 p-6 border border-white/10 hover:border-brand-gold/60 group transition-all duration-300"
        >
          <div class="w-12 h-12 rounded-full bg-brand-gold/15 flex items-center justify-center group-hover:bg-brand-gold/30 transition-colors duration-300 shrink-0">
            <svg class="w-6 h-6 text-brand-gold" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/>
            </svg>
          </div>
          <div>
            <p class="font-heading font-bold text-white text-base group-hover:text-brand-gold transition-colors duration-300">
              Send a Text / iMessage
            </p>
            <p class="font-body text-white/50 text-sm mt-1">Opens on your device</p>
          </div>
        </a>

        <!-- Call -->
        <a
          href="tel:+19034397666"
          class="contact-btn flex items-center gap-5 p-6 border border-white/10 hover:border-white/40 group transition-all duration-300"
        >
          <div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center group-hover:bg-white/20 transition-colors duration-300 shrink-0">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
          </div>
          <div>
            <p class="font-heading font-bold text-white text-base group-hover:text-white transition-colors duration-300">
              Call Us
            </p>
            <p class="font-body text-white/50 text-sm mt-1">903-439-7666</p>
          </div>
        </a>

      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const trigger = { trigger: '#contact', start: 'top 75%' };

  gsap.to('.contact-label', { opacity: 1, x: 0, duration: 0.7, ease: 'power3.out', scrollTrigger: trigger });
  gsap.to('#contact-heading', { clipPath: 'inset(0 0% 0 0)', duration: 1.3, ease: 'power3.inOut', scrollTrigger: trigger });
  gsap.to('.contact-sub', { opacity: 1, y: 0, duration: 0.8, delay: 0.3, scrollTrigger: trigger });

  gsap.set('.contact-label', { x: -30 });
  gsap.set('.contact-sub', { y: 20 });

  gsap.to('#contact-form', { opacity: 1, x: 0, duration: 1, ease: 'power3.out', delay: 0.2, scrollTrigger: trigger });
  gsap.to('#contact-buttons', { opacity: 1, x: 0, duration: 1, ease: 'power3.out', delay: 0.4, scrollTrigger: trigger });

  gsap.set('#contact-form', { x: -40 });
  gsap.set('#contact-buttons', { x: 40 });

  // Submit button hover
  const btn = document.getElementById('contact-submit');
  btn?.addEventListener('mouseenter', () => gsap.to(btn, { scale: 1.03, duration: 0.2 }));
  btn?.addEventListener('mouseleave', () => gsap.to(btn, { scale: 1, duration: 0.2 }));

  // Contact button hover lift
  document.querySelectorAll<HTMLElement>('.contact-btn').forEach(btn => {
    btn.addEventListener('mouseenter', () => gsap.to(btn, { y: -4, duration: 0.3, ease: 'power2.out' }));
    btn.addEventListener('mouseleave', () => gsap.to(btn, { y: 0, duration: 0.3, ease: 'power2.out' }));
  });
</script>

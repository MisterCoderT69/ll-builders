---
const services = [
  {
    icon: '/images/planoo.png',
    title: 'Custom Luxury Home Building',
    body: 'Your dream home, built to your exact specifications. We guide you through every design decision — from floor plan to finish — ensuring the final result reflects your family\'s lifestyle and taste.',
    accent: 'Residential',
  },
  {
    icon: '/images/commercial.png',
    title: 'Commercial Construction',
    body: 'From professional office buildings to retail spaces, we bring the same precision and craftsmanship we apply to residential builds. On time, on budget, built to last.',
    accent: 'Commercial',
  },
  {
    icon: '/images/lapiz-regla.png',
    title: 'Luxurious Lake Cabins',
    body: 'East Texas lake country is some of the most beautiful land in America. We build cabins that honor that beauty — rugged exteriors, refined interiors, and everything in between.',
    accent: 'Retreats',
  },
  {
    icon: '/images/martillo.png',
    title: 'Renovation & Remodeling',
    body: 'Whether you\'re updating a kitchen, adding square footage, or completely reimagining an existing structure, our team delivers renovation results at new-construction quality.',
    accent: 'Renovation',
  },
];
---

<section
  id="services"
  class="py-24 md:py-36 bg-brand-light overflow-hidden"
  aria-labelledby="services-heading"
>
  <div class="max-w-7xl mx-auto px-6 md:px-12">

    <!-- Heading -->
    <div class="mb-16 md:mb-20">
      <p class="services-label opacity-0 font-nav font-light text-brand-gold text-sm tracking-[0.3em] uppercase mb-4">
        What We Do
      </p>
      <h2
        id="services-heading"
        class="font-heading font-black text-5xl md:text-6xl lg:text-7xl text-white max-w-2xl leading-tight"
        style="clip-path: inset(0 100% 0 0);"
      >
        We Specialize In Excellence
      </h2>
    </div>

    <!-- Cards grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((service) => (
        <article class="service-card opacity-0 relative bg-brand-crimson/50 border border-white/10 p-8 group hover:border-brand-gold/40 transition-all duration-500 cursor-default overflow-hidden">

          <!-- Gold top border reveal on hover -->
          <div class="absolute top-0 left-0 w-0 h-[3px] bg-brand-gold transition-all duration-500 group-hover:w-full" />

          <!-- Accent label -->
          <span class="text-brand-gold/60 font-nav text-xs tracking-[0.2em] uppercase mb-6 block">
            {service.accent}
          </span>

          <!-- Icon -->
          <div class="service-icon mb-6 w-12 h-12 flex items-center justify-center">
            <img
              src={service.icon}
              alt={service.title}
              width="48"
              height="48"
              loading="lazy"
              class="w-12 h-12 object-contain filter brightness-75 group-hover:brightness-100 transition-all duration-300"
            />
          </div>

          <h3 class="font-heading text-xl text-white font-bold mb-4 leading-snug group-hover:text-brand-gold transition-colors duration-300">
            {service.title}
          </h3>
          <p class="font-accent text-white/65 text-base leading-relaxed">
            {service.body}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const trigger = { trigger: '#services', start: 'top 75%' };

  gsap.to('.services-label', { opacity: 1, x: 0, duration: 0.7, ease: 'power3.out', scrollTrigger: trigger });
  gsap.to('#services-heading', { clipPath: 'inset(0 0% 0 0)', duration: 1.3, ease: 'power3.inOut', scrollTrigger: trigger });

  gsap.set('.services-label', { x: -30 });
  gsap.set('.service-card', { y: 60 });

  gsap.to('.service-card', {
    opacity: 1,
    y: 0,
    duration: 0.8,
    stagger: 0.12,
    ease: 'power3.out',
    delay: 0.2,
    scrollTrigger: trigger,
  });

  // Card hover effects
  document.querySelectorAll<HTMLElement>('.service-card').forEach(card => {
    card.addEventListener('mouseenter', () => {
      gsap.to(card, { y: -8, duration: 0.3, ease: 'power2.out' });
    });
    card.addEventListener('mouseleave', () => {
      gsap.to(card, { y: 0, duration: 0.3, ease: 'power2.out' });
    });
  });
</script>

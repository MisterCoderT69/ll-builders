---
const navLinks = ['About', 'Services', 'Projects', 'Process', 'Contact'];
const year = new Date().getFullYear();
---

<footer
  id="site-footer"
  class="opacity-0 bg-brand-crimson border-t border-brand-gold/20 py-16 md:py-20"
>
  <div class="max-w-7xl mx-auto px-6 md:px-12">

    <div class="grid md:grid-cols-3 gap-12 md:gap-8 mb-12">

      <!-- Brand column -->
      <div>
        <a href="#hero" class="inline-block mb-6">
          <img
            src="/images/new_ll_logo.png"
            alt="L&L Builders logo"
            width="120"
            height="72"
            loading="lazy"
            class="w-28 object-contain"
          />
        </a>
        <p class="font-accent italic text-white/50 text-base leading-relaxed max-w-xs">
          Building East Texas, one dream at a time — since 1994.
        </p>
      </div>

      <!-- Navigate column -->
      <div>
        <h3 class="font-nav font-light text-brand-gold text-xs tracking-[0.3em] uppercase mb-6">Navigate</h3>
        <ul class="space-y-3">
          {navLinks.map(link => (
            <li>
              <a
                href={`#${link.toLowerCase()}`}
                class="footer-link font-body text-white/60 hover:text-brand-gold transition-colors duration-300 text-base flex items-center gap-2 group"
              >
                <span class="w-4 h-px bg-brand-gold/40 group-hover:w-6 transition-all duration-300" />
                {link}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <h3 class="font-nav font-light text-brand-gold text-xs tracking-[0.3em] uppercase mb-6">Get in Touch</h3>
        <ul class="space-y-4">
          <li>
            <a href="tel:+19034397666" class="footer-link font-body text-white/60 hover:text-brand-gold transition-colors duration-300 flex items-center gap-3">
              <span class="text-brand-gold/50 text-xs">TEL</span>
              903-439-7666
            </a>
          </li>
          <li>
            <a href="mailto:scarpenterenterprises@yahoo.com" class="footer-link font-body text-white/60 hover:text-brand-gold transition-colors duration-300 flex items-center gap-3 break-all">
              <span class="text-brand-gold/50 text-xs shrink-0">EMAIL</span>
              scarpenterenterprises@yahoo.com
            </a>
          </li>
          <li>
            <a
              href="https://wa.me/19034397666"
              target="_blank"
              rel="noopener noreferrer"
              class="footer-link font-body text-white/60 hover:text-[#25D366] transition-colors duration-300 flex items-center gap-3"
            >
              <span class="text-brand-gold/50 text-xs">WA</span>
              WhatsApp
            </a>
          </li>
          <li>
            <a
              href="#"
              class="footer-link font-body text-white/60 hover:text-brand-gold transition-colors duration-300 flex items-center gap-3"
            >
              <span class="text-brand-gold/50 text-xs">FB</span>
              Facebook
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-4 text-white/30 text-sm font-body">
      <p>&copy; {year} L&amp;L Builders, Inc. All rights reserved.</p>
      <p class="font-nav font-light tracking-widest text-xs uppercase">Sulphur Springs, Texas</p>
    </div>

  </div>
</footer>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.to('#site-footer', {
    opacity: 1,
    y: 0,
    duration: 0.9,
    ease: 'power3.out',
    scrollTrigger: { trigger: '#site-footer', start: 'top 95%' },
  });

  gsap.set('#site-footer', { y: 30 });
</script>
